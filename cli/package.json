{
  "name": "@mnemom/smoltbot",
  "version": "0.5.0",
  "description": "Transparent AI agent tracing - AAP compliant",
  "type": "module",
  "bin": {
    "smoltbot": "./dist/index.js"
  },
  "scripts": {
    "build": "npm install --prefix ../shared/policy-engine && npm run build --prefix ../shared/policy-engine && tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@mnemom/policy-engine": "file:../shared/policy-engine",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agent",
    "transparency",
    "aap",
    "alignment",
    "tracing",
    "observability",
    "openai",
    "gemini",
    "multi-provider",
    "gpt-5"
  ],
  "author": "Mnemom.ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnemom/smoltbot"
  },
  "homepage": "https://mnemom.ai",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
